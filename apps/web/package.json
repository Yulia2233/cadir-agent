    "react-dom": "19.1.0",
    "react-router": "7.7.1",
    "three": "0.178.0",
    "zustand": "5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@types/three": "0.178.1",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "9.31.0",
    "jsdom": "26.1.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.38.0",
