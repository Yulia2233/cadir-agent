# Public server configuration
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=8080
WEB_PORT=3000
PUBLIC_API_URL=http://localhost:8080
CADIR_VERSION=dev
EDGE_NETWORK=cadir-edge

# PostgreSQL
POSTGRES_DB=cadir
POSTGRES_USER=cadir
POSTGRES_PASSWORD=
DATABASE_URL=

# Redis and queues
REDIS_URL=redis://redis:6379/0

# Container operation
CONTAINER_LOG_MAX_SIZE=10m
CONTAINER_LOG_MAX_FILES=3

# S3-compatible object storage
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=cadir-artifacts
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Application encryption and authentication
SESSION_SECRET=
CSRF_SECRET=
MODEL_CONFIG_KEK=

# OpenCode and CAD workers are internal-only endpoints
OPENCODE_INTERNAL_URL=http://opencode:4096
OPENCODE_INTERNAL_USERNAME=opencode
OPENCODE_INTERNAL_PASSWORD=
OPENCODE_TOOL_TOKEN=
RUNNER_INTERNAL_URL=http://runner:8091
FREECAD_INTERNAL_URL=http://freecad-worker:8095
VALIDATOR_INTERNAL_URL=http://validator:8092
VIEWER_INTERNAL_URL=http://viewer:8093
CASE_SERVICE_INTERNAL_URL=http://case-service:8094
FREECAD_INTERNAL_URL=http://freecad-worker:8095

# Provider credentials are never committed; set these only in a secret store.
SYSTEM_MODEL_PROVIDER=
SYSTEM_MODEL_BASE_URL=
SYSTEM_MODEL_ID=
SYSTEM_MODEL_API_KEY=

# Agent repair policy
TASK_MAX_AUTO_ITERATIONS=4
