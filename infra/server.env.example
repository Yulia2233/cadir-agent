# Copy to a root-owned file outside the repository, for example
# /etc/cadir/cadir.env, and set permissions to 0600.
CADIR_VERSION=
EDGE_NETWORK=cadir-edge
CORS_ORIGINS=https://cad.example.com

POSTGRES_DB=cadir
POSTGRES_USER=cadir
POSTGRES_PASSWORD=
# Percent-encode reserved characters in the password component.
DATABASE_URL=

S3_REGION=us-east-1
S3_BUCKET=cadir-artifacts
S3_ACCESS_KEY=
S3_SECRET_KEY=

SESSION_SECRET=
CSRF_SECRET=
MODEL_CONFIG_KEK=

# Internal service authentication (keep these values in the server secret store).
OPENCODE_INTERNAL_USERNAME=opencode
OPENCODE_INTERNAL_PASSWORD=
OPENCODE_TOOL_TOKEN=

CONTAINER_LOG_MAX_SIZE=10m
CONTAINER_LOG_MAX_FILES=3

API_CPU_LIMIT=2.0
API_MEMORY_LIMIT=2G
WEB_CPU_LIMIT=1.0
WEB_MEMORY_LIMIT=512M
POSTGRES_CPU_LIMIT=2.0
POSTGRES_MEMORY_LIMIT=2G
REDIS_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=1G
MINIO_CPU_LIMIT=2.0
MINIO_MEMORY_LIMIT=2G
