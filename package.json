{
  "name": "cadir-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.14.0 <25"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --parallel --filter @cadir/api --filter @cadir/web dev",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "test:integration": "vitest run --config tests/vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "typecheck": "pnpm -r --if-present typecheck",
    "verify": "pnpm format && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "dev:up": "docker compose -f infra/compose.yaml up -d --build",
    "dev:down": "docker compose -f infra/compose.yaml down",
    "dev:health": "node scripts/healthcheck.mjs",
    "server:check": "node scripts/server-deploy.mjs check",
    "server:up": "node scripts/server-deploy.mjs up",
    "server:health": "node scripts/server-deploy.mjs health",
    "server:down": "node scripts/server-deploy.mjs down",
    "test:runner-container": "node tests/deployment/verify-runner-container.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.55.0",
    "@types/node": "24.1.0",
    "prettier": "3.6.2",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
